# =====================================
# ENVIRONMENT VARIABLES TEMPLATE
# =====================================
# Copy this file to .env and fill in with your actual values
# This single .env works for both development and production

# =====================================
# APP CONFIGURATION
# =====================================
APP_NAME=LoveLanguageApp
PORT=8080

# =====================================
# DATABASE CONFIGURATION - PostgreSQL
# =====================================
# Development: localhost:5432
# Production: your cloud database URL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/love_language_dev
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# =====================================
# JWT CONFIGURATION
# =====================================
# IMPORTANT: Generate strong secrets with: openssl rand -base64 32
# For development, simple strings work. For production, use strong secrets.
JWT_ACCESSKEY=dev_jwt_access_secret_key_min_32_chars_development_only
JWT_REFRESHKEY=dev_jwt_refresh_secret_key_min_32_chars_development_only
JWT_ACCESSEXPIRATION=900000
JWT_REFRESHEXPIRATION=604800000

# =====================================
# CORS CONFIGURATION
# =====================================
# Development: localhost ports
# Production: your domain
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# =====================================
# EMAIL CONFIGURATION (Optional)
# =====================================
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_password

# =====================================
# AWS S3 CONFIGURATION (Optional)
# =====================================
LONGVAN_ENDPOINT=https://s3.amazonaws.com
LONGVAN_REGION=us-east-1
LONGVAN_BUCKET=your-bucket-name
LONGVAN_ACCESS_KEY=your_aws_access_key
LONGVAN_SECRET_KEY=your_aws_secret_key

# =====================================
# CONNECTION POOL CONFIGURATION
# =====================================
DB_POOL_MAX=5
DB_POOL_MIN=1

